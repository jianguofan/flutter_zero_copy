{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter macOS (Debug)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "macos",
            "flutterMode": "debug"
        },
        {
            "name": "Flutter macOS (Debug + Build C++)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "macos",
            "flutterMode": "debug",
            "preLaunchTask": "Build cube_renderer"
        },
        {
            "name": "Flutter macOS (Profile)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "macos",
            "flutterMode": "profile"
        },
        {
            "name": "Flutter macOS (Release)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "macos",
            "flutterMode": "release"
        },

        {
            "name": "C++ Attach to cube_renderer (pick PID)",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/cube_renderer/build/cube_renderer",
            "pid": "${command:pickProcess}"
        }
    ]
}
